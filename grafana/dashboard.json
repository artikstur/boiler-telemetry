{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Boiler Telemetry — HTTP requests, errors, latency, cache hits",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Request Rate (RPS)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(rate({app=\"boiler-telemetry-api\"} |= \"HTTP\" [1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Error Rate (4xx+5xx)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(rate({app=\"boiler-telemetry-api\"} |= \"StatusCode\" | json | StatusCode >= 400 [1m])) / sum(rate({app=\"boiler-telemetry-api\"} |= \"HTTP\" [1m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Avg Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg_over_time({app=\"boiler-telemetry-api\"} |= \"ElapsedMs\" | json | unwrap ElapsedMs [5m])",
          "legendFormat": "avg latency ms"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "Anomalies Detected",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({app=\"anomaly-service\"} |= \"Anomaly detected\" [5m]))",
          "legendFormat": "anomalies"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "HTTP Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "RPS by Status Code",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (StatusCode) (rate({app=\"boiler-telemetry-api\"} |= \"StatusCode\" | json [1m]))",
          "legendFormat": "{{StatusCode}}"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Latency over time (ms)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg_over_time({app=\"boiler-telemetry-api\"} |= \"ElapsedMs\" | json | unwrap ElapsedMs [1m])",
          "legendFormat": "avg"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "quantile_over_time(0.95, {app=\"boiler-telemetry-api\"} |= \"ElapsedMs\" | json | unwrap ElapsedMs [1m])",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "quantile_over_time(0.99, {app=\"boiler-telemetry-api\"} |= \"ElapsedMs\" | json | unwrap ElapsedMs [1m])",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "title": "Errors & Anomalies",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "title": "Recent Errors (4xx / 5xx)",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{app=\"boiler-telemetry-api\"} | json | StatusCode >= 400",
          "legendFormat": ""
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "title": "Anomaly Events",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{app=\"anomaly-service\"} |= \"Anomaly detected\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 12,
      "title": "Redis Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 24 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Cache HIT vs MISS (API)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({app=\"boiler-telemetry-api\"} |= \"Cache HIT\" [1m]))",
          "legendFormat": "HIT"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({app=\"boiler-telemetry-api\"} |= \"Cache MISS\" [1m]))",
          "legendFormat": "MISS"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "id": 14,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Cache HIT vs MISS (AnomalyService)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({app=\"anomaly-service\"} |= \"Cache HIT\" [1m]))",
          "legendFormat": "HIT"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({app=\"anomaly-service\"} |= \"Cache MISS\" [1m]))",
          "legendFormat": "MISS"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["boiler-telemetry", "kubernetes", "dotnet"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki datasource",
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Boiler Telemetry",
  "uid": "boiler-telemetry-main",
  "version": 1
}
